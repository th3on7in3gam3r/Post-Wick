# Comma-separated Clerk login emails that can see platform ops UI (Meta setup checklist)
POSTWICK_PLATFORM_ADMIN_EMAILS=

# Auth (required) — use pk_live_ / sk_live_ keys in Vercel Production after Clerk domain is verified
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional but recommended in production:
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# App URL — use the port you run on (e.g. http://localhost:3001)
NEXT_PUBLIC_APP_URL=http://localhost:3001
# Sister product — Cadence workspace (growth stack Phase 1)
# NEXT_PUBLIC_AI_CMO_APP_URL=https://growth.biblefunland.com/app

# Database (Neon) — use pooler URL for serverless/Vercel
DATABASE_URL=
DATABASE_URL_DIRECT=
# AES-256 token encryption at rest — generate with: openssl rand -hex 32
ENCRYPTION_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# AI image generation — OpenAI first, Gemini second, Ideogram last
GEMINI_API_KEY=
# Optional: defaults to gemini-2.5-flash-image
GEMINI_IMAGE_MODEL=
IDEOGRAM_API_KEY=
# REQUIRED when DATABASE_URL is Neon (local dev shares the same DB as Vercel).
# Create a Blob store in Vercel → Storage, then copy BLOB_READ_WRITE_TOKEN to
# both Vercel env vars and .env.local so generated images upload to the cloud.
BLOB_READ_WRITE_TOKEN=

# LinkedIn publishing
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# X publishing — OAuth 2.0 from developer.x.com
# Redirect URI: {APP_URL}/api/social/x/callback
X_CLIENT_ID=
X_CLIENT_SECRET=

# Pinterest publishing — developers.pinterest.com
# Redirect URI: {APP_URL}/api/social/pinterest/callback
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
# Optional if Pinterest dashboard uses a different callback URL:
# PINTEREST_OAUTH_REDIRECT_URI=

# Meta / Instagram — use case: Manage messaging & content on Instagram
# Instagram Business Login (required for Connect Instagram):
#   INSTAGRAM_APP_ID + INSTAGRAM_APP_SECRET from Meta → Instagram → API setup with Instagram login → Business login settings
# Redirect URI (add in Business login settings → OAuth redirect URIs):
#   {APP_URL}/api/social/meta/callback
# If Meta added a trailing slash in the dashboard, set META_OAUTH_REDIRECT_URI to match exactly.
META_OAUTH_REDIRECT_URI=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Facebook Page OAuth — uses Facebook Login for Business (not classic scope login)
META_APP_ID=
META_APP_SECRET=
# Required for Business apps: Meta → Facebook Login for Business → Configurations → copy ID
META_FB_LOGIN_CONFIG_ID=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Yearly (preferred) — legacy aliases STRIPE_PRO_PRICE_ID / STRIPE_MAX_PRICE_ID also work
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_MAX_YEARLY_PRICE_ID=
# Monthly (optional — enables Monthly/Yearly toggle on billing page)
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_MAX_MONTHLY_PRICE_ID=
# Legacy yearly aliases (optional if YEARLY vars are set)
STRIPE_PRO_PRICE_ID=
STRIPE_MAX_PRICE_ID=

# Background jobs — ping with header Authorization: Bearer <CRON_SECRET>
#   GET /api/cron/publish         — publish due posts (every ~30 min)
#   GET /api/cron/queue-reminders — approval queue reminders (daily, e.g. 10am)
#   GET /api/cron/weekly-digest   — weekly digest emails (weekly, e.g. Mon 9am)
# Use cron-job.org on Hobby, or restore vercel.json crons on Pro.
CRON_SECRET=

# Contact form (Resend) — verify kerygmasocial.com in Resend, then use a from address on that domain
RESEND_API_KEY=
# Optional overrides (defaults: Kerygma Social <hello@kerygmasocial.com> → hello@kerygmasocial.com)
# RESEND_FROM_EMAIL=
# CONTACT_TO_EMAIL=
# New signup onboarding notifications (defaults to jerlessm@gmail.com)
# ONBOARDING_NOTIFY_EMAIL=
# Integration failure alerts (user + admin). Defaults to ONBOARDING_NOTIFY_EMAIL.
# INTEGRATION_ALERT_EMAIL=

# Studio Ops — internal event feed (same secret as studio-ops/.env.local)
STUDIO_OPS_URL=http://localhost:3010
STUDIO_OPS_WEBHOOK_SECRET=
