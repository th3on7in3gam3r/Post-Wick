# Comma-separated Clerk login emails that can see platform ops UI (Meta setup checklist)
POSTWICK_PLATFORM_ADMIN_EMAILS=

# Auth (required) — use pk_live_ / sk_live_ keys in Vercel Production after Clerk domain is verified
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional but recommended in production:
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# App URL — use the port you run on (e.g. http://localhost:3001)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Database (Neon) — use pooler URL for serverless/Vercel
DATABASE_URL=
DATABASE_URL_DIRECT=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# AI image generation — OpenAI first, Gemini second, Ideogram last
GEMINI_API_KEY=
# Optional: defaults to gemini-2.5-flash-image
GEMINI_IMAGE_MODEL=
IDEOGRAM_API_KEY=
# REQUIRED when DATABASE_URL is Neon (local dev shares the same DB as Vercel).
# Create a Blob store in Vercel → Storage, then copy BLOB_READ_WRITE_TOKEN to
# both Vercel env vars and .env.local so generated images upload to the cloud.
BLOB_READ_WRITE_TOKEN=

# LinkedIn publishing
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# X publishing — OAuth 2.0 from developer.x.com
# Redirect URI: {APP_URL}/api/social/x/callback
X_CLIENT_ID=
X_CLIENT_SECRET=

# Meta / Instagram — use case: Manage messaging & content on Instagram
# Instagram Business Login (required for Connect Instagram):
#   INSTAGRAM_APP_ID + INSTAGRAM_APP_SECRET from Meta → Instagram → API setup with Instagram login → Business login settings
# Redirect URI (add in Business login settings → OAuth redirect URIs):
#   {APP_URL}/api/social/meta/callback
# If Meta added a trailing slash in the dashboard, set META_OAUTH_REDIRECT_URI to match exactly.
META_OAUTH_REDIRECT_URI=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Facebook Page OAuth — uses Facebook Login for Business (not classic scope login)
META_APP_ID=
META_APP_SECRET=
# Required for Business apps: Meta → Facebook Login for Business → Configurations → copy ID
META_FB_LOGIN_CONFIG_ID=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_MAX_PRICE_ID=

# Background publishing — Vercel Cron sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
