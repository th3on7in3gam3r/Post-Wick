# Auth (required)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# App URL — use the port you run on (e.g. http://localhost:3001)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Database (Neon) — use pooler URL for serverless/Vercel
DATABASE_URL=
DATABASE_URL_DIRECT=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# AI image generation — OpenAI is tried first, Ideogram is fallback
IDEOGRAM_API_KEY=
# Required on Vercel when OpenAI generates images (base64). Not needed if only Ideogram works.
BLOB_READ_WRITE_TOKEN=

# LinkedIn publishing
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_MAX_PRICE_ID=
