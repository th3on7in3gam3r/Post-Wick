# Auth (required)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# App URL — use the port you run on (e.g. http://localhost:3001)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Database (Neon) — use pooler URL for serverless/Vercel
DATABASE_URL=
DATABASE_URL_DIRECT=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# AI image generation — OpenAI first, Gemini second, Ideogram last
GEMINI_API_KEY=
# Optional: defaults to gemini-2.5-flash-image
GEMINI_IMAGE_MODEL=
IDEOGRAM_API_KEY=
# Required on Vercel when OpenAI or Gemini generates images (base64). Not needed if only Ideogram works.
BLOB_READ_WRITE_TOKEN=

# LinkedIn publishing
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Meta / Instagram — use case: Manage messaging & content on Instagram
# Redirect URI (add in Instagram → API setup with Instagram login → Business login settings):
#   {APP_URL}/api/social/meta/callback
# Prefer Instagram App ID + Secret from the Instagram login setup page (optional overrides below).
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_MAX_PRICE_ID=

# Background publishing — Vercel Cron sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
